{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Agentyx",
  "version": "0.1.0",
  "identifier": "io.agentyx.app",
  "build": {
    "beforeDevCommand": "bun run dev:ui",
    "beforeBuildCommand": "bun run build:ui",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agentyx",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": [
          "'self'",
          "tauri:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'",
          "tauri:"
        ],
        "img-src": [
          "'self'",
          "data:",
          "blob:",
          "tauri:"
        ],
        "font-src": [
          "'self'",
          "data:",
          "tauri:"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "ws://localhost:1420"
        ],
        "media-src": [
          "'self'",
          "data:",
          "blob:",
          "tauri:"
        ],
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'",
        "frame-ancestors": "'none'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$HOME/**",
          "$RESOURCE/**",
          "$TEMP/**",
          "$VIDEO/**"
        ]
      }
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "shortDescription": "Agentyx — fast, lightweight, agentic desktop app.",
    "longDescription": "Agentyx is a desktop app that turns open-source LLM code into autonomous productivity agents. You ask, Agentyx coordinates the work to get it done.",
    "copyright": "Copyright (c) 2026 Manuel Iglesias-Sarria",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": null,
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {}
}
